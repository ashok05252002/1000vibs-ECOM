# Environment
.env
.env.testing

# IDEs
.idea/
.vscode/
.vagrant/

# PHP
.php_cs.cache
.phpunit.result.cache

# Node
/node_modules/
npm-debug.log
package-lock.json
yarn.lock
yarn-error.log

# Vite / Hot Reload
*.hot*
/public/hot

# Playwright
/playwright-report/
/test-results/

# Laravel Vendor
/vendor/

# Laravel Storage
/storage/*.key
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/framework/testing/*
/storage/dcc-data/

# Uploaded Files (Bagisto)
# These will remain on the server and be backed up separately.
# Do NOT store product/category/customer images in Git.
/storage/app/public/*
!/storage/app/public/.gitignore

# Bootstrap Cache
/bootstrap/cache/*.php

# Public Generated Files
/public/css/
/public/js/
/public/storage
/public/vendor
/public/build/
# Language Vendor Files
/lang/vendor/

# Misc
*/stubs*
*/data*
*/docker-compose-collection*
*/ignorables/*
*Homestead.json*
*Homestead.yaml*